# KopiyanteaPOS — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Supabase project URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase publishable key (`sb_publishable_...`) — Settings → API in the
# Supabase dashboard. The legacy JWT anon key also works here, but the
# publishable key is the recommended replacement (per-key revocation,
# rotation-friendly). NEVER place a secret/service_role key on the client.
SUPABASE_PUBLISHABLE_KEY=

# Environment: development | staging | production
APP_ENV=development

# Comma-separated SHA-256 cert fingerprints for Supabase cert pinning (production only).
# Format: AA:BB:CC:...  Include current + next fingerprint during rotation overlap.
SUPABASE_CERT_FINGERPRINTS=
